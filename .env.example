# Zoho Books CLI — sample environment file
# Copy to .env for local use. Never commit real values.

# Obtain these by creating a "Server-based Application" at https://api-console.zoho.com/
# Redirect URI must be: http://localhost:8976/callback
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# Region: us | eu | in | au | jp | ca | sa
# Determines which accounts.zoho.<tld> and www.zohoapis.<tld> domains are used.
ZOHO_REGION=us

# Default organization_id for requests. Run `zb org list` to find yours, then
# either set here or run `zb org use <org_id>`.
ZOHO_ORG_ID=

# Headless / CI path: bypass keyring entirely by supplying a refresh token.
# Generate once via `zb auth login` on a workstation, then copy the token from
# keyring (see docs) or re-run the OAuth flow headlessly.
ZOHO_REFRESH_TOKEN=
